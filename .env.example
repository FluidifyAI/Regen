# Fluidify Regen — Environment Variables
# Copy this file to .env and fill in your values.
# cp .env.example .env

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_DB=regen
POSTGRES_USER=regen
POSTGRES_PASSWORD=changeme                  # Change this in production!
DATABASE_URL=postgresql://regen:changeme@db:5432/regen

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=production                          # development | production
PORT=8080
APP_URL=http://localhost:8080               # Public URL of the backend (used for webhooks, SAML callbacks)
FRONTEND_URL=http://localhost:8080          # Public URL served to users (same as APP_URL if using embedded frontend)
CORS_ALLOWED_ORIGINS=http://localhost:8080  # Comma-separated list of allowed origins

# ── Slack (optional) ───────────────────────────────────────────────────────────
# Required for Slack channel auto-creation, bot commands, and @mention AI bot.
# See: https://github.com/FluidifyAI/Regen/blob/main/slack-app-manifest.yaml
SLACK_BOT_TOKEN=                            # xoxb-... (Bot User OAuth Token)
SLACK_SIGNING_SECRET=                       # From Slack App → Basic Information → Signing Secret
SLACK_APP_TOKEN=                            # xapp-... (App-Level Token, required for Socket Mode)

# ── Microsoft Teams (optional) ─────────────────────────────────────────────────
# Required for Teams channel auto-creation and bot commands.
TEAMS_APP_ID=                               # Azure App Registration → Application (client) ID
TEAMS_APP_PASSWORD=                         # Azure App Registration → Client Secret value
TEAMS_TENANT_ID=                            # Azure Active Directory → Tenant ID
TEAMS_SERVICE_URL=https://smba.trafficmanager.net/amer/  # Bot Framework relay (amer|emea|in|apac)

# ── Telegram (optional) ────────────────────────────────────────────────────────
# Configured via the in-app Settings → Integrations → Telegram UI after startup.
# These are stored in the database, not required as env vars.

# ── AI / OpenAI (optional) ─────────────────────────────────────────────────────
# BYO key — your incident data never leaves your infrastructure.
# Enables: incident summarization, post-mortem drafts, @mention Q&A bot.
OPENAI_API_KEY=                             # sk-...

# ── SSO / SAML (optional) ──────────────────────────────────────────────────────
# Works with Okta, Azure AD, Google Workspace, and any SAML 2.0 IdP.
# SSO is free — we stay off sso.tax.
SAML_ENABLED=false
SAML_IDP_METADATA_URL=                      # https://your-idp/metadata
SAML_SP_ENTITY_ID=                          # e.g. https://yourdomain.com/saml/metadata
SAML_SP_ACS_URL=                            # e.g. https://yourdomain.com/saml/acs (auto-derived if blank)

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info                              # debug | info | warn | error
