# OpenIncident Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# Application Settings
# ============================================================================

# Environment: development, production
APP_ENV=development

# Log level: debug, info, warn, error
LOG_LEVEL=info

# ============================================================================
# Database Configuration (PostgreSQL)
# ============================================================================

# PostgreSQL database name
POSTGRES_DB=openincident

# PostgreSQL username
POSTGRES_USER=openincident

# PostgreSQL password (REQUIRED - change in production!)
POSTGRES_PASSWORD=secret

# PostgreSQL port (default: 5432)
POSTGRES_PORT=5432

# ============================================================================
# Redis Configuration
# ============================================================================

# Redis port (default: 6379)
REDIS_PORT=6379

# ============================================================================
# API Service Configuration
# ============================================================================

# API server port (default: 8080)
API_PORT=8080

# ============================================================================
# Frontend Configuration
# ============================================================================

# Frontend port (default: 3000)
WEB_PORT=3000

# API URL for frontend (default: http://localhost:8080)
VITE_API_URL=http://localhost:8080

# ============================================================================
# Slack Integration (REQUIRED for Slack features)
# ============================================================================
# Get these values from https://api.slack.com/apps

# Slack Bot Token (starts with xoxb-)
# Required scopes: chat:write, channels:manage, channels:read, users:read
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Slack Signing Secret (for webhook verification)
# Found in: Basic Information > App Credentials
SLACK_SIGNING_SECRET=your-signing-secret-here

# Slack App Token (starts with xapp-) - OPTIONAL
# Only needed for Socket Mode (development without public webhook URL)
SLACK_APP_TOKEN=xapp-your-app-token-here

# ============================================================================
# AI Integration (OPTIONAL - for incident summarization)
# ============================================================================

# OpenAI API Key (starts with sk-)
# Get from: https://platform.openai.com/api-keys
# Leave empty to disable AI features
OPENAI_API_KEY=sk-your-openai-key-here

# ============================================================================
# Notes
# ============================================================================
#
# REQUIRED variables for basic functionality:
# - POSTGRES_PASSWORD (change from default!)
# - SLACK_BOT_TOKEN
# - SLACK_SIGNING_SECRET
#
# OPTIONAL variables:
# - SLACK_APP_TOKEN (for local development without ngrok)
# - OPENAI_API_KEY (for AI summarization features)
#
# All port variables have sensible defaults and can be omitted.
#
